{
  "extends": "astro/tsconfigs/strict",
  "include": [
    ".astro/types.d.ts",
    "**/*"
  ],
  "exclude": [
    "dist"
  ],
  "compilerOptions": {
    "module": "esnext",
    "moduleResolution": "node",
    "target": "es2023",
    "strict": true,
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "strictNullChecks": true,
    "allowJs": true,
    "jsxImportSource": "react",
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ]
    }
  }
}