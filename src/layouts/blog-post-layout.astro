---
import Container from "@/components/container";
import { prisma } from "@/lib/prisma";
import { capitalizeFirstLetter } from "@/lib/utils";
import Layout from "@/pages/layout.astro";
import { format } from "date-fns";
import { Image } from "astro:assets";
import {
    Calendar,
    ExternalLink,
    Github,
    Tags,
    User,
    Youtube,
} from "lucide-react";
import RelatedPostsComponent from "@/content/related-posts-component.astro";
const { frontmatter } = Astro.props;

const profileData = await prisma.user.findFirst({
    where: {
        name: frontmatter.author,
    },
    select: {
        image: true,
        name: true,
        role: true,
        id: true,
    },
});

if (!profileData) throw new Error("Author not found");
---

<Layout subtitle={frontmatter.title} description={frontmatter.description}>
    <main class="flex flex-col items-center gap-2 justify-center">
        <article
            class="flex flex-col items-start gap-2 justify-center lg:max-w-[85%] max-w-full"
        >
            <div
                class="grid md:grid-cols-2 grid-cols-1 place-items-between gap-4"
            >
                <div class="flex flex-col gap-4 p-4">
                    <nav aria-label="Breadcrumb" class="mb-2">
                        <ol
                            class="flex items-center space-x-2 text-sm text-neutral-600 dark:text-neutral-400"
                        >
                            <li>
                                <a
                                    href="/"
                                    class="hover:underline hover:text-primary-600 transition-colors"
                                    >Home</a
                                >
                            </li>
                            <li>
                                <span class="mx-1">/</span>
                            </li>
                            <li>
                                <a
                                    href="/blog"
                                    class="hover:underline hover:text-primary-600 transition-colors"
                                    >Blog</a
                                >
                            </li>
                            <li>
                                <span class="mx-1">/</span>
                            </li>
                            <li
                                aria-current="page"
                                class="font-semibold text-neutral-900 dark:text-neutral-100"
                            >
                                {frontmatter.title}
                            </li>
                        </ol>
                    </nav>
                    <h1 class="text-4xl !font-black">{frontmatter.title}</h1>
                    <p class="text-neutral-900 dark:text-neutral-300">
                        {frontmatter.description}
                    </p>
                    <div class="flex items-center gap-4">
                        <p class="flex items-center gap-1">
                            <User />
                            {profileData.name}
                        </p>

                        <p class="flex items-center gap-1">
                            <Calendar />
                            {format(frontmatter.pubDate, "dd.MM.yyyy")}
                        </p>
                    </div>
                </div>
                <div
                    class="w-full flex items-center md:justify-end justify-center"
                >
                    <img
                        src={frontmatter.image}
                        class="w-full max-w-xs corner-squircle rounded-lg"
                        width={500}
                        alt={frontmatter.title}
                    />
                </div>
            </div>
            <section
                class="flex md:justify-between justify-center w-full gap-4 items-start flex-wrap"
            >
                <Container
                    className="bg-white dark:bg-neutral-900 !p-8 dark:border-neutral-800"
                >
                    <div
                        class="prose dark:prose-invert prose-h1:text-2xl prose-h2:text-xl prose-p:text-base"
                    >
                        <h1 class="text-3xl font-bold">{frontmatter.title}</h1>
                        <slot />
                    </div>
                    <RelatedPostsComponent
                        relatedPosts={frontmatter.relatedPosts}
                    />
                </Container>

                <Container
                    className="md:sticky md:top-34 relative top-0 w-fit p-8 flex flex-col gap-8 dark:bg-neutral-950 dark:border-neutral-800"
                >
                    <div class="flex items-center gap-4">
                        <Calendar />
                        <div>
                            Published date: <p class="font-bold">
                                {format(frontmatter.pubDate, "dd.MM.yyyy")}
                            </p>
                        </div>
                    </div>

                    <div class="space-y-2">
                        <p class="flex items-center gap-1">
                            <Tags />
                            Tags:
                        </p>

                        <div class="flex items-center flex-wrap gap-1">
                            {
                                frontmatter.tags.map((tag: string) => (
                                    <div class="bg-secondary-600 text-white corner-squircle rounded-full px-3 py-1 text-sm">
                                        {tag}
                                    </div>
                                ))
                            }
                        </div>
                    </div>

                    <div class="space-y-2">
                        <p class="flex items-center gap-1">
                            <User />
                            Author:
                        </p>

                        <div
                            class="bg-background-950 dark:bg-neutral-900 corner-squircle rounded-sm px-4 py-6 border-[1px] border-background-800 dark:border-neutral-700"
                        >
                            <div class="flex items-center gap-4">
                                <Image
                                    src={profileData?.image!}
                                    alt="Profile image"
                                    class="rounded-full w-22 h-22"
                                    width={96}
                                    height={96}
                                />
                                <div class="">
                                    <a
                                        href={"/profile/" + profileData.name}
                                        class="hover:underline transition-all"
                                    >
                                        <h3
                                            class="text-2xl font-medium leading-8 flex items-center gap-2"
                                        >
                                            {profileData.name}
                                            <ExternalLink size={18} />
                                        </h3>
                                    </a>
                                    <p class="text-primary-500">
                                        {
                                            capitalizeFirstLetter(
                                                profileData.role.toLowerCase(),
                                            )
                                        }
                                    </p>
                                    <div
                                        class="mt-2 text-sm flex items-center gap-2 flex-wrap"
                                    >
                                        <a
                                            href={"https://www.youtube.com/@floyare"}
                                            class="text-black transition-colors flex items-center gap-1 bg-accent-800 corner-squircle rounded-md px-3 py-1 border-[1px] border-accent-700"
                                        >
                                            <Youtube /> Youtube Channel
                                        </a>

                                        <a
                                            href={"https://github.com/floyare"}
                                            class="text-black transition-colors flex items-center gap-1 bg-accent-800 corner-squircle rounded-md px-3 py-1 border-[1px] border-accent-700"
                                        >
                                            <Github /> Github Profile
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </Container>
            </section>
        </article>
    </main>
</Layout>
