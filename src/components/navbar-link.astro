---
const siteUrl = Astro.url;
const { url, className } = Astro.props;
---

<a
    href={url}
    class:list={[
        "flex gap-2 xl:p-2 py-8 px-8 items-center cursor-pointer hover:text-text-500 focus:text-text-600 transition-colors xl:w-fit w-full justify-center xl:hover:bg-transparent hover:bg-background-700",
        siteUrl.pathname === url
            ? "text-text-400 dark:text-text-600 font-bold"
            : "",
        className,
    ]}
>
    <slot />
</a>
