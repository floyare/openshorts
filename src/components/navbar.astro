---
export const prerender = false;
import { Compass, LoaderCircle, UploadCloud } from "lucide-react";
import Logo from "./logo.astro";
import NavigationState from "./navigation-state.astro";

const url = Astro.url;
---

<nav class="w-full flex items-center justify-center p-4">
    <div class="flex flex-col items-center gap-6">
        <Logo className="!scale-110" />
        <div
            class="flex items-center justify-center gap-8 bg-white rounded-full sm:!px-12 !px-6 py-3 border-[1px] border-background-800"
        >
            <a
                href="/"
                class:list={[
                    "flex flex-col items-center cursor-pointer sm:text-xl text-sm hover:text-text-500 focus:text-text-600 transition-colors",
                    url.pathname === "/" ? "text-text-400 font-bold" : "",
                ]}
            >
                <Compass size={32} /> Browse
            </a>

            <a
                href="/upload"
                class:list={[
                    "flex flex-col items-center cursor-pointer sm:text-xl text-sm hover:text-text-500 focus:text-text-600 transition-colors",
                    url.pathname === "/upload" ? "text-text-400 font-bold" : "",
                ]}
            >
                <UploadCloud size={32} /> Upload
            </a>

            {
                Astro.isPrerendered ? (
                    <NavigationState server:defer slot="auth">
                        <a
                            slot="fallback"
                            href="/signin"
                            class="flex flex-col items-center cursor-pointer sm:text-xl text-sm hover:text-text-500 focus:text-text-600 transition-colors text-center grayscale-100 pointer-events-none opacity-70"
                        >
                            <LoaderCircle size={32} className="animate-spin" />{" "}
                            Loading...
                        </a>
                    </NavigationState>
                ) : (
                    <NavigationState />
                )
            }
        </div>
    </div>
</nav>
