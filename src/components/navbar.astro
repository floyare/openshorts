---
import { Compass, LogIn, UploadCloud, User } from "lucide-react";
import Logo from "./logo.astro";
---

<nav class="w-full flex items-center justify-center p-4">
    <div class="flex flex-col items-center gap-6">
        <Logo />
        <div
            class="flex items-center justify-center gap-8 bg-white rounded-full sm:!px-12 !px-6 py-3 border-[1px] border-background-800"
        >
            <a
                href="/"
                class="flex flex-col items-center cursor-pointer sm:text-xl text-sm hover:text-text-500 focus:text-text-600 transition-colors"
            >
                <Compass size={32} /> Browse
            </a>

            <a
                href="/upload"
                class="flex flex-col items-center cursor-pointer sm:text-xl text-sm hover:text-text-500 focus:text-text-600 transition-colors"
            >
                <UploadCloud size={32} /> Upload
            </a>

            {
                Astro.locals.user ? (
                    <a
                        href="/profile"
                        class="flex flex-col items-center cursor-pointer sm:text-xl text-sm hover:text-text-500 focus:text-text-600 transition-colors"
                    >
                        <User size={32} /> Profile
                    </a>
                ) : (
                    <a
                        href="/signin"
                        class="flex flex-col items-center cursor-pointer sm:text-xl text-sm hover:text-text-500 focus:text-text-600 transition-colors text-center"
                    >
                        <LogIn size={32} /> Sign In
                    </a>
                )
            }
        </div>
    </div>
</nav>
