---
export const prerender = false;
import {
    ArrowRight,
    ChevronRight,
    Compass,
    LoaderCircle,
    Newspaper,
    UploadCloud,
} from "lucide-react";
import Logo from "./logo.astro";
import NavigationState from "./navigation-state.astro";

const url = Astro.url;
---

<nav class="w-full flex items-center justify-center" transition:name="navbar">
    <div class="flex flex-col items-center gap-6">
        <Logo className="!scale-110" />
        <div
            class="flex items-center justify-center gap-8 bg-white dark:bg-neutral-800 dark:text-text-950 rounded-full sm:!px-12 !px-6 py-3 border-[1px] border-background-800 dark:border-neutral-700"
        >
            <a
                href="/"
                class:list={[
                    "flex flex-col items-center cursor-pointer sm:text-xl text-sm hover:text-text-500 focus:text-text-600 transition-colors",
                    url.pathname === "/"
                        ? "text-text-400 dark:text-text-600 font-bold"
                        : "",
                ]}
            >
                <Compass size={32} /> Browse
            </a>

            <a
                href="/upload"
                class:list={[
                    "flex flex-col items-center cursor-pointer sm:text-xl text-sm hover:text-text-500 focus:text-text-600 transition-colors",
                    url.pathname === "/upload"
                        ? "text-text-400 dark:text-text-600 font-bold"
                        : "",
                ]}
            >
                <UploadCloud size={32} /> Upload
            </a>

            <a
                href="/blog"
                class:list={[
                    "flex flex-col items-center cursor-pointer sm:text-xl text-sm hover:text-text-500 focus:text-text-600 transition-colors",
                    url.pathname.includes("/blog")
                        ? "text-text-400 dark:text-text-600 font-bold"
                        : "",
                ]}
            >
                <Newspaper size={32} /> Blog
            </a>

            {
                Astro.isPrerendered ? (
                    <NavigationState server:defer slot="auth">
                        <a
                            slot="fallback"
                            href="/signin"
                            class:list={[
                                "flex flex-col items-center cursor-pointer sm:text-xl text-sm hover:text-text-500 focus:text-text-600 transition-colors text-center grayscale-100 pointer-events-none opacity-70",
                                url.pathname === "/signin"
                                    ? "!text-text-400 dark:text-text-600 font-bold"
                                    : "",
                            ]}
                        >
                            <LoaderCircle size={32} className="animate-spin" />{" "}
                            Loading...
                        </a>
                    </NavigationState>
                ) : (
                    <NavigationState />
                )
            }
        </div>
        <a
            href="/blog"
            class="bg-background-500 text-white px-4 py-2 -mt-4 rounded-md flex items-center justify-center gap-1 flex-wrap"
        >
            <p class="text-center text-balance break-words">
                ✨ Our <b>Awesome Blog</b> is Now available!
            </p>

            <ArrowRight />
        </a>
    </div>
</nav>
