---
import { ExternalLink } from "lucide-react";
import { Button } from "../ui/button";

interface Props {
    website: {
        name: string;
        url: string;
        description: string;
        image: string;
    };
}

const { website } = Astro.props;
const { name, url, description, image } = website;
---

<div
    class="px-6 py-4 max-w-md rounded-sm border-[1px] border-background-800 bg-background-950 w-fit flex flex-col gap-2 grow"
>
    <div class="flex items-start gap-4">
        <div class="flex flex-col gap-2">
            <div class="flex items-center gap-4">
                <img
                    src={`https://s2.googleusercontent.com/s2/favicons?domain=${url}&sz=128`}
                    width="48"
                    height="48"
                />
                <div>
                    <h3 class="text-xl font-semibold">{name}</h3>
                </div>
            </div>
            <p
                class="w-full overflow-hidden text-ellipsis [display:-webkit-box] [-webkit-line-clamp:6] [-webkit-box-orient:vertical]"
            >
                {description}
            </p>
            <Button variant={"primary"}>Visit website <ExternalLink /></Button>
        </div>
        <img src={image} width="150px" height="350px" class="rounded-xs" />
    </div>
</div>
