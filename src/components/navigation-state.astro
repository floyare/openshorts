---
import { LogIn, User } from "lucide-react";

const url = Astro.url;
---

{
    Astro.locals.user ? (
        <a
            href="/profile"
            class:list={[
                "flex gap-2 xl:p-2 p-4 px-8 items-center cursor-pointer sm:text-xl text-sm hover:text-text-500 focus:text-text-600 transition-colors",
                url.pathname.includes("/profile")
                    ? "text-text-400 dark:text-text-600 font-bold"
                    : "",
            ]}
        >
            <User size={32} /> Profile
        </a>
    ) : (
        <a
            href="/signin"
            class:list={[
                "flex gap-2 xl:p-2 p-4 px-8 items-center cursor-pointer sm:text-xl text-sm hover:text-text-500 focus:text-text-600 transition-colors text-center",
                url.pathname === "/signin"
                    ? "!text-text-400 dark:text-text-600 font-bold"
                    : "",
            ]}
        >
            <LogIn size={32} /> Sign In
        </a>
    )
}
