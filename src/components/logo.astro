---
const { ...props } = Astro.props;
---

<h1
    {...props}
    class:list={[
        "text-4xl font-bold flex items-center gap-4 select-none",
        props.class,
    ]}
>
    open
    <span class="text-text-950 relative">
        <div
            class="absolute bottom-[50%] rounded-md translate-y-[50%] left-[50%] -translate-x-[50%] w-[calc(100%+25px)] h-full bg-background-500 -skew-6 -z-10 py-6"
        >
        </div>
        <p class="text-3xl mb-0.5">shorts</p>
    </span>
</h1>
