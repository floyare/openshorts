---
const { ...props } = Astro.props;
---

<h1
    class:list={[
        "text-4xl font-bold flex items-center gap-5 select-none tracking-tighter z-20",
        props.className,
    ]}
    {...props}
>
    open
    <span class="text-text-950 relative">
        <div
            class="absolute bottom-[50%] corner-squircle rounded-md translate-y-[50%] left-[50%] -translate-x-[50%] w-[calc(100%+25px)] h-full bg-background-500 -skew-6 -z-10 py-6"
        >
        </div>
        <div class="text-3xl">shorts</div>
    </span>
</h1>
