---
import Container from "@/components/container";
import Layout from "./layout.astro";
import { Image } from "astro:assets";
---

<Layout
    subtitle="About project"
    description="OpenShorts is a platform where people can share and discover useful websites and online tools."
>
    <section class="flex flex-col items-center gap-8">
        <Container className="flex items-start gap-6 max-w-2xl !py-6 !px-12">
            <Image
                src="/favicon.png"
                alt="About openshorts"
                class=""
                width={100}
                height={100}
                format="webp"
                quality={50}
            />
            <div class="flex flex-col items-start gap-2">
                <h1 class="text-3xl font-bold flex items-center">
                    About open<span class="text-text-500">shorts</span>.
                </h1>
                <p class="text-lg text-gray-700">
                    OpenShorts is a platform where people can share and discover
                    useful websites and online tools. Users can upload their own
                    finds, explore what others have shared, and interact by
                    liking and commenting on the content. It's designed to be
                    easy to use and encourages a community of developers,
                    designers, and digital creators to connect and collaborate.
                </p>
                <!-- <p class="text-lg text-gray-700">
                    The project is built with a focus on community engagement,
                    allowing users to contribute, share, and interact with tools
                    and websites in a meaningful way.
                </p> -->
            </div>
        </Container>
    </section>
</Layout>
