---
import Layout from "../layout.astro";
import { format } from "date-fns";
import BlogPosts from "../../components/blog/blog-posts.tsx";

const allPosts = Object.values(
    await import.meta.glob("../../content/blog/*.mdx", { eager: true }),
);
---

<Layout subtitle="Blog posts">
    <section class="flex flex-col my-8">
        <header class="text-3xl font-extrabold tracking-tight">
            Blog posts
        </header>
        <p>Search by topics you are interested in.</p>
        <BlogPosts posts={allPosts} client:idle />
    </section>
</Layout>
