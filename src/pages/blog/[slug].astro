---
import {
    getCollection,
    getEntry,
    render,
    type CollectionEntry,
} from "astro:content";
import Layout from "../layout.astro";
import BlogPostLayout from "@/layouts/BlogPostLayout.astro";
import ArticleSchema from "@/constants/schemas/ArticleSchema.astro";
import BreadcrumbSchema from "@/constants/schemas/BreadcrumbSchema.astro";

interface Props {
    post: CollectionEntry<"blog">;
}

export async function getStaticPaths() {
    const posts = await getCollection("blog");
    return posts.map((post) => ({
        params: { slug: post.slug },
        props: { post },
    }));
}

const { post } = Astro.props;
const entry = await getEntry("blog", post.slug);
if (!entry) throw new Error("Blog post not found");
const { Content, headings } = await render(entry);

/*

    {
        "@type": "ListItem",
        position: 1,
        name: "Blog",
        item: `${import.meta.env.SITE}`,
    },
    {
        "@type": "ListItem",
        position: 2,
        name: entry.data.title,
        item: `${import.meta.env.SITE}/${entry.slug}/`,
    }
*/
---

<ArticleSchema {...post.data} />
<BreadcrumbSchema
    items={[
        {
            "@type": "ListItem",
            position: 1,
            name: "Blog",
            item: `${import.meta.env.SITE}/blog/`,
        },
        {
            "@type": "ListItem",
            position: 2,
            name: entry.data.title,
            item: `${import.meta.env.SITE}/blog/${entry.slug}/`,
        },
    ]}
/>
<BlogPostLayout frontmatter={entry.data}>
    <Content />
</BlogPostLayout>
