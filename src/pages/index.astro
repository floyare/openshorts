---
export const prerender = false;

import { Button } from "@/components/ui/button";
import Layout from "./layout.astro";
import { getPrismaInstance } from "@/lib/prisma";
import { PackageOpen } from "lucide-react";
import SkewedHighlight from "@/components/skewed-highlight";
import WebsiteBrowser from "@/components/website-browser";
import Container from "@/components/container.astro";
import { getAvailableTags } from "@/lib/websites.core";
import { debugLog } from "@/lib/log";

// TODO: font https://fonts.google.com/specimen/Dongle

const [websites, totalCount] = await Promise.all([
    getPrismaInstance().websites.findMany({
        take: 20,
    }),
    getPrismaInstance().websites.count(),
]);

const tags = await getAvailableTags();
debugLog("DEBUG", tags);
---

<Layout subtitle="test">
    <main class="flex flex-col items-center gap-8">
        <div class="flex flex-col gap-2 items-start">
            <SkewedHighlight>
                <h2
                    class="text-xl font-semibold text-text-950 flex items-center gap-1"
                >
                    <PackageOpen /> Recently added
                </h2>
            </SkewedHighlight>
            <!-- <Container>
                <h2 class="text-xl font-semibold text-text-500 flex items-center gap-1"><PackageOpen /> Recently added</h2>
            </Container> -->
            <Container
                class="w-full min-w-3xl flex items-center justify-center gap-4 flex-wrap"
            >
                <p>{JSON.stringify(tags)}</p>
                <WebsiteBrowser
                    entryWebsites={websites}
                    totalWebsites={totalCount}
                    client:idle
                />
            </Container>
        </div>
    </main>
</Layout>
