---
import Layout from "../layout.astro";
import WebsiteBrowser from "@/components/website-browser";
import type { User } from "better-auth";
//import { actions } from "astro:actions";
---

<Layout
    subtitle="Browse websites"
    description="Explore through our huge collection of useful and productive websites uploaded by other users."
>
    <main class="flex flex-col gap-8">
        <div class="flex flex-col gap-2 items-start py-8">
            <section id="browse" class="space-y-4 w-full">
                <div>
                    <h1 class="text-3xl font-extrabold tracking-tight">
                        Browse websites
                    </h1>
                    <p>
                        Explore through our huge collection of useful and
                        productive websites.
                    </p>
                </div>
                <WebsiteBrowser
                    currentUser={(Astro.locals.user as User) ?? undefined}
                    client:idle
                />
            </section>
        </div>
    </main>
</Layout>
