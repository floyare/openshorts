---
import { Schema } from "astro-seo-schema";
const { title, description, pubDate, author, image, url } = Astro.props;
---

<Schema
    item={{
        "@context": "https://schema.org",
        "@type": "Article",
        headline: title,
        description,
        datePublished:
            pubDate && !isNaN(new Date(pubDate).getTime())
                ? new Date(pubDate).toISOString()
                : undefined,
        url,
        image: { "@type": "ImageObject", url: image, caption: title },
        author: {
            "@type": "Person",
            name: author,
            url: `${import.meta.env.SITE}/profile/${author}`,
        },
        publisher: {
            "@type": "Organization",
            name: "www.openshorts.dev",
            logo: {
                "@type": "ImageObject",
                url: `${import.meta.env.SITE}/favicon.png`,
            },
        },
    }}
/>
