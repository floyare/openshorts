---
import { Schema } from "astro-seo-schema";
const { siteUrl, siteTitle, siteDescription } = Astro.props;

const socialProfiles = [
    "https://www.youtube.com/@floyare",
    "https://github.com/floyare",
    "https://x.com/floyarestyles",
];
---

<Schema
    item={{
        "@context": "https://schema.org",
        "@graph": [
            {
                "@type": "WebSite",
                name: siteTitle,
                url: siteUrl,
                description: siteDescription,
                publisher: {
                    "@type": "Organization",
                    name: siteTitle,
                    logo: {
                        "@type": "ImageObject",
                        url: `${siteUrl}/favicon.png`,
                    },
                },
                potentialAction: {
                    "@type": "SearchAction",
                    target: `${siteUrl}/search?q={search_term_string}`,
                    query: "required name=search_term_string",
                },
            },
            {
                "@type": "WebPage",
                "@id": `${siteUrl}`,
                url: siteUrl,
                name: siteTitle,
                description: siteDescription,
                isPartOf: { "@id": `${siteUrl}` },
                mainEntityOfPage: { "@id": `${siteUrl}` },
            },
            {
                "@type": "Person",
                "@id": `${siteUrl}/profile/floyare`,
                name: "floyare",
                alternateName: "floyarestyles",
                url: siteUrl,
                image: {
                    "@type": "ImageObject",
                    url: "https://avatars.githubusercontent.com/u/40760726?v=4",
                },
                sameAs: socialProfiles,
                jobTitle: "Frontend Developer",
                description:
                    "openshorts.dev owner, content creator on YouTube, and developer.",
            },
        ],
    }}
/>
