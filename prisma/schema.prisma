generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model websites {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  description String?
  url         String     @unique
  image       String
  category    categories
  tags        String[]   @default([])
  created_by  String
}

enum categories {
  PROGRAMMING
  UI_UX           @map("UI/UX")
  GRAPHICS_DESIGN @map("GRAPHICS DESIGN")
}
