generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model websites {
  id                  String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                String
  description         String?
  url                 String       @unique
  image               String?
  category            categories
  tags                String[]     @default([])
  created_at          DateTime     @default(now()) @db.Timestamp(6)
  created_by          String
  last_preview_update DateTime     @default(now()) @db.Timestamp(6)
  hidden              Boolean      @default(false)
  user_likes          user_likes[]
  user                User         @relation(fields: [created_by], references: [name], onDelete: Cascade, map: "created_by_key")
}

model User {
  id             String       @id
  name           String       @unique
  email          String       @unique
  emailVerified  Boolean
  image          String?
  createdAt      DateTime
  updatedAt      DateTime
  role           user_role    @default(USER)
  banned_details Json         @default("[]") @db.Json
  ai_usage       Json?        @db.Json
  accounts       Account[]
  sessions       Session[]
  user_likes     user_likes[]
  websites       websites[]

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}

model user_likes {
  user_id    String
  website_id String   @db.Uuid
  liked_at   DateTime @default(now()) @db.Timestamp(6)
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade, map: "user_id_key")
  websites   websites @relation(fields: [website_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([user_id, website_id])
}

enum categories {
  PROGRAMMING
  UI_UX           @map("UI/UX")
  GRAPHICS_DESIGN @map("GRAPHICS DESIGN")
}

enum user_role {
  USER
  OWNER
  MODERATOR
}
